class DummyDataset(Dataset):
    def __init__(
            self,
            length=100,
            rad_size=(256, 107, 64),
            rae_size=(256, 107, 37), 
            det_gt_size=(256, 107, 37),
            max_objects=8,
            num_classes=10,
            box_dim=7
            ):
         super().__init__()
         self.length=length
         self.rad_size=rad_size
         self.rae_size=rae_size
         self.det_gt_size=det_gt_size
         self.max_objects=max_objects
         self.num_classes=num_classes
         self.box_dim=box_dim

    def __len__(self):
        return self.length

    def __getitem__(self, index):
        num_objects = torch.randint(0, self.max_objects + 1, (1,)).item()

        return {
             'rad':torch.randn(*self.rad_size),
             'rae':torch.randn(*self.rae_size),
             'det_gt':torch.randn(*self.det_gt_size),
             'gt_boxes':torch.randn(num_objects, self.box_dim),
             'gt_labels':torch.randint(0, self.num_classes, (num_objects,), dtype=torch.long),
        }


def dummy_detection_collate(batch):
    collated = {
        'rad': torch.stack([item['rad'] for item in batch], dim=0),
        'rae': torch.stack([item['rae'] for item in batch], dim=0),
        'gt_boxes': [item['gt_boxes'] for item in batch],
        'gt_labels': [item['gt_labels'] for item in batch],
    }

    if 'det_gt' in batch[0]:
        collated['det_gt'] = torch.stack([item['det_gt'] for item in batch], dim=0)

    return collated


class KRadarGTDetectionDataset(Dataset):
    def __init__(
            self,
            label_dir,
            radar_dataset,
            gt_txt_path,
            label_files=None
            ):
        super().__init__()
        self.label_dir = label_dir
        self.label_files = label_files
        if self.label_files is None:
            self.label_files = get_label_files(label_dir)

        self.radar_dataset = radar_dataset
        self.gt_by_os2_idx = read_gt_txt(gt_txt_path)

    def __len__(self):
        return len(self.label_files)

    def __getitem__(self, index):
        label_path = f"{self.label_dir}/{self.label_files[index]}"
        info_label = read_info_label(label_path)

        os2_64_idx = int(info_label["os2_64_idx"])
        objects = self.gt_by_os2_idx.get(os2_64_idx, [])

        radar_data = self.radar_dataset.get_by_tesseract_idx(
            info_label["tesseract_idx"]
        )

        rad = torch.from_numpy(radar_data["rad"]).float()
        rae = torch.from_numpy(radar_data["rea"]).float()

        if len(objects) > 0:
            gt_boxes = torch.stack([obj["box_aer"] for obj in objects], dim=0)
            gt_labels = torch.tensor(
                [obj["object_label"] for obj in objects],
                dtype=torch.long
            )
        else:
            gt_boxes = torch.zeros((0, 7), dtype=torch.float32)
            gt_labels = torch.zeros((0,), dtype=torch.long)

        return {
            "rad": rad,
            "rae": rae,
            "gt_boxes": gt_boxes,
            "gt_labels": gt_labels,
        }



class RadarConvBlock(nn.Module):
    def __init__(self,in_channels,out_channels):
        super().__init__()
        self.model=nn.Sequential(
            nn.Conv2d(in_channels, 128, kernel_size=3, padding=1, dilation=1),
            nn.BatchNorm2d(128),
            nn.LeakyReLU(inplace=True),
            nn.Conv2d(128, out_channels, kernel_size=3, padding=1, dilation=1),
            nn.BatchNorm2d(out_channels),
            nn.LeakyReLU(inplace=True)
        )

    def forward(self,x: torch.Tensor) -> torch.Tensor:
        x = self.model(x)
        return x
    
class Radar3DTensorEncoder(nn.Module):
    def __init__(self,input_size,output_size):
        super().__init__()
        d_in, r_in, a_in = input_size
        fd, fr, fa = output_size
        self.fr = fr
        self.fa = fa
        self.conv_block_d = RadarConvBlock(in_channels=d_in, out_channels=fd)
        self.conv_block_r = RadarConvBlock(in_channels=r_in, out_channels=fr)
        self.conv_block_a = RadarConvBlock(in_channels=a_in, out_channels=fa)
 
    def forward(self, x: torch.Tensor) : 
        f_d: torch.Tensor = self.conv_block_d(x) 
        x_r: torch.Tensor = f_d.permute(0, 2, 1, 3).contiguous()
        f_r: torch.Tensor = self.conv_block_r(x_r)    
        x_a: torch.Tensor = f_r.permute(0, 3, 2, 1).contiguous()    
        f_a: torch.Tensor = self.conv_block_a(x_a)
        x:   torch.Tensor = f_a.permute(0, 2, 3, 1).contiguous()                                           
        return x

class Radar3DTensorDecoder(nn.Module):
    def __init__(self,input_size,output_size):
        super().__init__()
        fea_c, fea_h, fea_w = input_size
        num_boxes, bbx_parameter = output_size

        self.backbone = RadarConvBlock(
            in_channels=fea_c,
            out_channels=num_boxes
        )
        self.output_head = nn.Linear(fea_h * fea_w, bbx_parameter)  #h*w -> bbx_parameter


    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x = self.backbone(x) # (B, num_boxes, H, W)
        x = x.view(x.shape[0], x.shape[1], -1)  # (B, num_boxes, H*W)
        x = self.output_head(x)              # (B, num_boxes, pred_dim)
        return x
    


class MVRSS3DModel(nn.Module):
    def __init__(
            self,rad_input_size,
            rae_input_size,
            feature_size,
            det_gt_size
            ):

        super().__init__()

        self.rad_encoder = Radar3DTensorEncoder(input_size=rad_input_size, output_size=feature_size)
        self.rae_encoder = Radar3DTensorEncoder(input_size=rae_input_size, output_size=feature_size)

        self.decoder = Radar3DTensorDecoder(input_size=feature_size, output_size=det_gt_size)

        self.det_output_size = det_gt_size

        num_feature_channels, H, W = feature_size
        self.fusion = nn.Sequential(
            nn.Conv2d(num_feature_channels*2, num_feature_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(num_feature_channels),
            nn.LeakyReLU(inplace=True),
            nn.Conv2d(num_feature_channels, num_feature_channels, kernel_size=3, padding=1),
            nn.BatchNorm2d(num_feature_channels),
            nn.LeakyReLU(inplace=True)
        )

        
    def forward(self,batch):

        rad= batch['rad']
        rae= batch['rae']

        # enoder
        f_rad = self.rad_encoder(rad)
        f_rae = self.rae_encoder(rae)

        # latent feature fusion
        f_fusion = torch.cat([f_rad, f_rae], dim=1)
        fused_features = self.fusion(f_fusion)

        output = self.decoder(fused_features)
        
        return output


def build_padded_targets(
        gt_boxes_list,
        gt_labels_list,
        num_queries,
        box_dim,
        num_classes,
        device
    ):
    B = len(gt_boxes_list)

    target_boxes = torch.zeros(
        B,
        num_queries,
        box_dim,
        dtype=torch.float32,
        device=device
    )

    target_classes = torch.full(
        (B, num_queries),
        fill_value=num_classes,
        dtype=torch.long,
        device=device
    )

    positive_mask = torch.zeros(
        B,
        num_queries,
        dtype=torch.bool,
        device=device
    )

    for b in range(B):
        gt_boxes = gt_boxes_list[b].to(device)
        gt_labels = gt_labels_list[b].to(device)

        num_gt = min(gt_boxes.shape[0], num_queries)

        if num_gt == 0:
            continue

        target_boxes[b, :num_gt] = gt_boxes[:num_gt]
        target_classes[b, :num_gt] = gt_labels[:num_gt]
        positive_mask[b, :num_gt] = True

    return target_boxes, target_classes, positive_mask


def detection_loss(
        outputs,
        gt_boxes_list,
        gt_labels_list,
        num_classes,
        box_loss_weight=1.0,
        cls_loss_weight=1.0
    ):
    device = outputs.device

    box_dim = 7
    num_queries = outputs.shape[1]
    expected_output_dim = box_dim + num_classes + 1

    if outputs.shape[-1] != expected_output_dim:
        raise ValueError(
            f"Expected output dim {expected_output_dim}, got {outputs.shape[-1]}"
        )

    pred_boxes = outputs[:, :, :box_dim]
    pred_logits = outputs[:, :, box_dim:]

    target_boxes, target_classes, positive_mask = build_padded_targets(
        gt_boxes_list=gt_boxes_list,
        gt_labels_list=gt_labels_list,
        num_queries=num_queries,
        box_dim=box_dim,
        num_classes=num_classes,
        device=device
    )

    cls_loss = F.cross_entropy(
        pred_logits.reshape(-1, num_classes + 1),
        target_classes.reshape(-1)
    )

    if positive_mask.any():
        box_loss = F.smooth_l1_loss(
            pred_boxes[positive_mask],
            target_boxes[positive_mask]
        )
    else:
        box_loss = torch.tensor(0.0, device=device)

    total_loss = (
        box_loss_weight * box_loss
        + cls_loss_weight * cls_loss
    )

    loss_dict = {
        "total_loss": total_loss.item(),
        "box_loss": box_loss.item(),
        "cls_loss": cls_loss.item()
    }

    return total_loss, loss_dict



if __name__ == "__main__":
    numClasses = 10

    BatchSize = 4
    rad_input_size = (256, 107, 64)
    rae_input_size = (256, 107, 37)
    feature_size = (128, 24, 64)

    num_boxes = 64
    det_gt_size = (num_boxes, 7+numClasses+1)
    
    #dataset = KRadarDataset("/home/local/xinyu/KRadar/1/radar_tesseract")
    dataset = DummyDataset(length=100,rad_size=rad_input_size, rae_size=rae_input_size,
                           det_gt_size=det_gt_size, num_classes=numClasses)
    
    dataloader = DataLoader(
        dataset,
        batch_size=BatchSize,
        shuffle=True,
        collate_fn=dummy_detection_collate
    )

    model = MVRSS3DModel(
        rad_input_size=rad_input_size, 
        rae_input_size=rae_input_size,
        feature_size=feature_size,
        det_gt_size=det_gt_size
        ).to('cuda')
    
    optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)
    model.train()

    
    for i,batch in enumerate(dataloader):
        batch['rad'] = batch['rad'].to('cuda')
        batch['rae'] = batch['rae'].to('cuda')
        batch['det_gt'] = batch['det_gt'].to('cuda')

        print(batch['rad'].shape)
        print(batch['rae'].shape)
        print(batch['det_gt'].shape)

        outputs = model(batch)
        assert outputs.shape == batch['det_gt'].shape, f"Output shape {outputs.shape} does not match target shape {batch['det_gt'].shape}"
        if outputs.shape != batch['det_gt'].shape:
            raise ValueError(f"Output shape {outputs.shape} does not match target shape {batch['det_gt'].shape}")

        loss, loss_dict = detection_loss(
            outputs=outputs,
            gt_boxes_list=batch['gt_boxes'],
            gt_labels_list=batch['gt_labels'],
            num_classes=numClasses,
            box_loss_weight=1.0,
            cls_loss_weight=1.0
        )

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        print(
            f"iter={i}, "
            f"loss={loss_dict['total_loss']:.4f}, "
            f"box={loss_dict['box_loss']:.4f}, "
            f"cls={loss_dict['cls_loss']:.4f}"
        )
        break
